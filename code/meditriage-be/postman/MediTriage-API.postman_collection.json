{
	"info": {
		"name": "MediTriage API - Complete",
		"description": "Comprehensive Postman collection for testing all MediTriage backend endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "patient_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "encounter_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register Nurse",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has user data\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData).to.have.property('username');",
									"    pm.expect(jsonData.role).to.eql('NURSE');",
									"    pm.collectionVariables.set('user_id', jsonData.id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"nurse_jane\",\n  \"email\": \"jane@hospital.com\",\n  \"password\": \"SecurePass123\",\n  \"full_name\": \"Jane Doe\",\n  \"role\": \"NURSE\",\n  \"license_number\": \"NUR12345\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					}
				},
				{
					"name": "Register Doctor",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"dr_smith\",\n  \"email\": \"smith@hospital.com\",\n  \"password\": \"DoctorPass456\",\n  \"full_name\": \"Dr. John Smith\",\n  \"role\": \"DOCTOR\",\n  \"license_number\": \"DOC67890\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('access_token', jsonData.access_token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"nurse_jane\",\n  \"password\": \"SecurePass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "login"]
						}
					}
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/me",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "me"]
						}
					}
				},
				{
					"name": "Update Own Profile",
					"request": {
						"method": "PATCH",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"full_name\": \"Jane Doe Updated\",\n  \"license_number\": \"NUR54321\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/me",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "me"]
						}
					}
				}
			]
		},
		{
			"name": "Patient Management",
			"item": [
				{
					"name": "Create Patient",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('patient_id', jsonData.id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"national_id\": \"123456789V\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Patient\",\n  \"date_of_birth\": \"1990-05-15\",\n  \"gender\": \"MALE\",\n  \"contact_number\": \"+94771234567\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/patients",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "patients"]
						}
					}
				},
				{
					"name": "Search Patient by NIC",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/patients/search?nic=123456789V",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "patients", "search"],
							"query": [{"key": "nic", "value": "123456789V"}]
						}
					}
				},
				{
					"name": "Search Patient by Name",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/patients/search?name=John",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "patients", "search"],
							"query": [{"key": "name", "value": "John"}]
						}
					}
				},
				{
					"name": "Get Patient by ID",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/patients/{{patient_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "patients", "{{patient_id}}"]
						}
					}
				},
				{
					"name": "Update Patient",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"gender\": \"PREFER_NOT_TO_SAY\",\n  \"contact_number\": \"+94777654321\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/patients/{{patient_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "patients", "{{patient_id}}"]
						}
					}
				},
				{
					"name": "Get Patient History",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/patients/{{patient_id}}/history",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "patients", "{{patient_id}}", "history"]
						}
					}
				},
				{
					"name": "Delete Patient (Admin)",
					"request": {
						"method": "DELETE",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/patients/{{patient_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "patients", "{{patient_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "User Management",
			"item": [
				{
					"name": "List Users (Admin)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/users?skip=0&limit=10",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users"],
							"query": [
								{"key": "skip", "value": "0"},
								{"key": "limit", "value": "10"}
							]
						}
					}
				},
				{
					"name": "Deactivate User (Admin)",
					"request": {
						"method": "DELETE",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/users/{{user_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users", "{{user_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "Triage & Clinical",
			"item": [
				{
					"name": "Start Triage Interview",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('encounter_id', jsonData.encounter_id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"patient_id\": \"{{patient_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/triage/start",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "triage", "start"]
						}
					}
				},
				{
					"name": "Send Chat Message",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"encounter_id\": \"{{encounter_id}}\",\n  \"message\": \"I have a severe headache for 3 days\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/triage/chat",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "triage", "chat"]
						}
					}
				},
				{
					"name": "Get Chat Messages",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/triage/{{encounter_id}}/messages",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "triage", "{{encounter_id}}", "messages"]
						}
					}
				},
				{
					"name": "Update Urgency (Nurse)",
					"request": {
						"method": "PATCH",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"is_urgent\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/triage/{{encounter_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "triage", "{{encounter_id}}"]
						}
					}
				},
				{
					"name": "Get Clinical Note",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "{{base_url}}/api/v1/triage/{{encounter_id}}/note",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "triage", "{{encounter_id}}", "note"]
						}
					}
				},
				{
					"name": "Update Clinical Note (Doctor)",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"subjective\": \"Patient reports severe headache for 3 days (Updated by Doctor)\",\n  \"objective\": \"BP: 120/80, HR: 75\",\n  \"assessment\": \"Likely tension headache\",\n  \"plan\": \"Prescribe pain relief, follow-up in 1 week\",\n  \"is_finalized\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/triage/{{encounter_id}}/note",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "triage", "{{encounter_id}}", "note"]
						}
					}
				}
			]
		},
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Root Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/",
							"host": ["{{base_url}}"],
							"path": [""]
						}
					}
				}
			]
		}
	]
}
